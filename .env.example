# ========================================
# CryptoSignal Auto-Execution Configuration
# ========================================
# Copy this file to .env.local (development) or .env.production (production)
# and fill in the required values

# -------- Environment --------
ENVIRONMENT=production
LOG_LEVEL=info
DEBUG=false

# -------- Database --------
# PostgreSQL with TimescaleDB
DATABASE_URL=postgresql://crypto_user:password@localhost:5432/crypto_signals
DB_NAME=crypto_signals
DB_USER=crypto_user
DB_PASSWORD=secure_password_here
DB_HOST=db
DB_PORT=5432

# -------- Redis --------
# For caching and rate limiting
REDIS_URL=redis://:password@redis:6379/0
REDIS_PASSWORD=redis_password_here
REDIS_PORT=6379

# -------- Encryption --------
# Used for encrypting stored API keys
ENCRYPTION_KEY=generate_with_cryptography_lib_fernet
API_KEY_SALT=random_salt_for_hashing

# -------- API Configuration --------
# CORS and API settings
CORS_ORIGINS=["https://cryptosignal.app", "https://staging.cryptosignal.app"]
API_TIMEOUT_SECONDS=30
RATE_LIMIT_PER_MINUTE=60

# -------- Binance Configuration --------
# Your bot's Binance credentials (for live trading)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TEST_MODE=false

# -------- Trading Configuration --------
# Default trading settings
DEFAULT_TRADING_MODE=PAPER
DEFAULT_WALLET_BALANCE=10000.0
MAX_POSITION_SIZE_PERCENT=5
MIN_POSITION_SIZE_USDТ=10

# -------- Auto-Execution --------
# Signal confidence thresholds
VERY_HIGH_CONFIDENCE_THRESHOLD=85
HIGH_CONFIDENCE_THRESHOLD=75
MEDIUM_CONFIDENCE_THRESHOLD=55

# Auto-execution multipliers
AUTO_EXEC_VERY_HIGH_SIZE=1.0
AUTO_EXEC_HIGH_SIZE=0.8
AUTO_EXEC_RECOVERY_SIZE=0.5

# -------- Drawdown Recovery --------
# Drawdown thresholds
ACTIVE_DD_MAX=5
CAUTION_DD_MIN=5
CAUTION_DD_MAX=15
RECOVERY_DD_MIN=15
RECOVERY_DD_MAX=25
PAUSED_DD_MIN=25

# Position size multipliers during recovery
CAUTION_POSITION_MULTIPLIER=0.75
RECOVERY_POSITION_MULTIPLIER=0.5

# -------- Frontend Configuration --------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ENVIRONMENT=production

# -------- Monitoring & Logging --------
# Structured logging and metrics
LOG_FORMAT=json
METRICS_ENABLED=true
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# -------- Cloud Platform Credentials --------
# AWS (if using AWS for deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_ECR_REGISTRY=your_ecr_registry
AWS_ECS_CLUSTER=crypto-signals-production
AWS_ECS_SERVICE=crypto-signals-backend

# Vercel (if using Vercel for frontend)
VERCEL_TOKEN=your_vercel_token
VERCEL_ORG_ID=your_org_id
VERCEL_PROJECT_ID=your_project_id

# GCP (if using Google Cloud)
GCP_PROJECT_ID=your_gcp_project
GCP_SERVICE_ACCOUNT_KEY=path_to_service_account_json

# -------- Slack Notifications --------
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#deployments
SLACK_MENTIONS=@channel

# -------- Email/SMS Alerts --------
# For trade notifications (optional)
SENDGRID_API_KEY=your_sendgrid_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
ALERT_EMAIL=admin@cryptosignal.app
ALERT_PHONE=+1234567890

# -------- Security --------
# JWT/API Key settings
JWT_SECRET=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
API_KEY_LENGTH=32

# -------- Feature Flags --------
ENABLE_AUTO_EXECUTION=true
ENABLE_PAPER_TRADING=true
ENABLE_LIVE_TRADING=false
ENABLE_NOTIFICATIONS=true
ENABLE_AUDIT_LOGGING=true

# -------- Performance --------
WORKER_THREADS=4
MAX_CONNECTIONS=100
QUERY_TIMEOUT_MS=5000
CACHE_TTL_MINUTES=5
