# CryptoSignal AI — Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# ── API Configuration ──────────────────────────────────────────────────────
# Public URL of the FastAPI backend. The frontend never calls this directly
# from the browser — next.config.js uses it as the server-side rewrite target
# for /api/* (so there is no CORS or HTTPS mixed-content to configure).
# Local dev: http://localhost:8000
# Production (Vercel): set this to your deployed backend, e.g.
#   https://crypto-signals-backend.onrender.com   (must be a NON-US region —
#   Binance returns HTTP 451 to US cloud IPs)
NEXT_PUBLIC_API_URL=http://localhost:8000

# API Key for authentication (required to access trading endpoints)
# Get your key from the backend admin or use demo-key-public for testing
NEXT_PUBLIC_API_KEY=demo-key-public

# ── Error Tracking (Sentry) ────────────────────────────────────────────────
# Optional: Set to your Sentry DSN to enable error tracking
# Get a free DSN at https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=

# ── Analytics (optional) ───────────────────────────────────────────────────
NEXT_PUBLIC_GA_TRACKING_ID=

# ── Feature Flags ──────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_ADVANCED_CHARTS=true
NEXT_PUBLIC_ENABLE_BACKTESTING=true
NEXT_PUBLIC_ENABLE_RESEARCH=true
