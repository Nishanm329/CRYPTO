{
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "description": "Backend API URL",
      "required": true
    },
    "NEXT_PUBLIC_ENVIRONMENT": {
      "description": "Environment name",
      "default": "production"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://crypto-signals-api.vercel.app/api/:path*"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.11"
    }
  },
  "regions": ["sfo1"],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
