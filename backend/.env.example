# CryptoSignal AI — Backend Environment Variables
# Copy this file to .env and fill in your values

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# ── External APIs ───────────────────────────────────────────────────────────
# Binance API (optional, uses public endpoints by default)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Fear & Greed Index API
FEAR_GREED_API_KEY=

# ── Monitoring ──────────────────────────────────────────────────────────────
# Prometheus metrics are exposed at /metrics
PROMETHEUS_ENABLED=true

# Sentry (optional, for error tracking)
SENTRY_DSN=

# ── Circuit Breaker Config ──────────────────────────────────────────────────
# Failure threshold before opening circuit
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Time in seconds before attempting to reset circuit
CIRCUIT_BREAKER_TIMEOUT=60

# ── Rate Limiting (requests/minute) ────────────────────────────────────────
RATE_LIMIT_SCAN=30
RATE_LIMIT_SIGNAL=60
RATE_LIMIT_CHART=60
RATE_LIMIT_MARKET=20

# ── CORS Configuration ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ── Server Configuration ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Database Configuration (PostgreSQL) ─────────────────────────────────────
# TimescaleDB (PostgreSQL extension) for time-series data
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crypto_signals

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Enable SQL echo (debug mode)
SQL_ECHO=false

# ── API Key Authentication ──────────────────────────────────────────────────
# Format: key1:user1,key2:user2
# Demo key for testing
API_KEYS=demo-key-public:demo-user
