# CryptoSignal AI — Production Environment Configuration
# Copy to .env.production and fill in your values

# ── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Database (PostgreSQL + TimescaleDB) ─────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=changeme  # CHANGE THIS!
DB_HOST=postgres
DB_PORT=5432
DB_NAME=crypto_signals
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme  # CHANGE THIS!

# ── Server Configuration ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── External APIs ───────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
FEAR_GREED_API_KEY=your_fear_greed_api_key

# ── Monitoring ──────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true

# Sentry for error tracking (REQUIRED in production)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── API Keys (Bearer token authentication) ──────────────────────────────────
# Format: key1:user1,key2:user2,key3:user3
# DO NOT use demo keys in production!
API_KEYS=your-production-key-1:company-a,your-production-key-2:company-b

# ── CORS Configuration (REQUIRED in production) ─────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://cryptosignal.com,https://app.cryptosignal.com

# ── Frontend Configuration ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.cryptosignal.com
NEXT_PUBLIC_API_KEY=your-production-key-1
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Circuit Breaker (Binance API resilience) ───────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60

# ── Rate Limiting (requests per minute) ─────────────────────────────────────
RATE_LIMIT_SCAN=30
RATE_LIMIT_SIGNAL=60
RATE_LIMIT_CHART=60
RATE_LIMIT_MARKET=20

# ── SSL/TLS Certificates (for Nginx) ────────────────────────────────────────
# Certificates should be placed in:
#   ./ssl/certs/fullchain.pem
#   ./ssl/certs/privkey.pem
#   ./ssl/dhparam.pem
# Generate with Let's Encrypt:
#   certbot certonly --standalone -d cryptosignal.com -d api.cryptosignal.com
# Or use your own CA:
#   openssl req -new -x509 -days 365 -nodes -keyout privkey.pem -out fullchain.pem

# ── Production Checklist ────────────────────────────────────────────────────
# [ ] Change all "changeme" passwords
# [ ] Set API_KEYS to production keys (not demo)
# [ ] Configure CORS_ORIGINS for your domain
# [ ] Set SENTRY_DSN for error tracking
# [ ] Add SSL certificates
# [ ] Update NEXT_PUBLIC_API_URL to production domain
# [ ] Test database connection before deploying
# [ ] Set up monitoring and alerting
# [ ] Configure log aggregation (e.g., ELK stack)
# [ ] Enable rate limiting for production traffic
